# Backend environment variables (copy to backend/.env)

# Server
PORT=5000
NODE_ENV=development

# Render (production) notes:
# - Set NODE_ENV=production
# - Render provides PORT automatically (you usually don't set PORT manually)

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority

# Optional: override DNS servers for MongoDB Atlas SRV lookups if your network blocks SRV/DNS.
# Example:
# DNS_SERVERS=8.8.8.8,1.1.1.1
DNS_SERVERS=

# Auth
JWT_SECRET=change_me

# Base URL used when building password reset links.
# If set, the reset link is built like: ${BACKEND_URL}/reset-password?token=<TOKEN>
# Examples:
# BACKEND_URL=https://german-bharatham-backend.onrender.com
BACKEND_URL=https://german-bharatham-backend.onrender.com

# Deprecated (older name). Not used by current code.
USER_RESET_PASSWORD_URL_BASE=

# SMTP (email sending)
# Example for Gmail SMTP (use an App Password, not your normal password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="German Bharatham <your-email@gmail.com>"
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional SMTP flags
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# Optional: ONLY for development debugging (returns resetLink in API response)
# DEV_RETURN_RESET_LINK=true
DEV_RETURN_RESET_LINK=false

# ── Social Login (Google / Facebook / Apple) ───────────────────────────────
# Google Sign-In (recommended flow in this app):
# - The mobile app sends an `idToken` (preferred).
# - The backend verifies the `idToken` audience against allowed client IDs.
#
# Fallback (when Android sign-in can't obtain an idToken):
# - The mobile app can send an `accessToken`.
# - The backend validates it via tokeninfo + fetches userinfo.
#
# Set one of these:
# - GOOGLE_CLIENT_IDS: comma-separated list of allowed OAuth client IDs
#   (Android/iOS/Web) OR
# - GOOGLE_CLIENT_ID: single allowed OAuth client ID
#
# Also supported (legacy / explicit naming):
# - GOOGLE_ANDROID_CLIENT_ID: Android OAuth client id
# - GOOGLE_IOS_CLIENT_ID: iOS OAuth client id
# - GOOGLE_WEB_CLIENT_ID: Web OAuth client id
#
# Recommended: put ALL of them in GOOGLE_CLIENT_IDS.
GOOGLE_CLIENT_IDS=
# GOOGLE_CLIENT_ID=

# Optional / not required for ID-token verification.
# Needed only if you implement an OAuth "authorization code" exchange on the backend.
GOOGLE_CLIENT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay webhook secret (create in Razorpay dashboard → Webhooks)
# Local/testing value is OK; for production use the real secret.
RAZORPAY_WEBHOOK_SECRET=

# Subscriptions pricing (INR)
SUBSCRIPTIONS_CURRENCY=
SUBSCRIPTIONS_MONTHLY_PRICE_INR=
SUBSCRIPTIONS_YEARLY_PRICE_INR=

# Durations (days)
SUBSCRIPTIONS_MONTHLY_DAYS=
SUBSCRIPTIONS_YEARLY_DAYS=

# Home popup after N days
SUBSCRIPTIONS_PROMPT_AFTER_DAYS=