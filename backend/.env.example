# Backend environment variables (copy to backend/.env)

# Server
PORT=5000
NODE_ENV=development

# Render (production) notes:
# - Set NODE_ENV=production
# - Render provides PORT automatically (you usually don't set PORT manually)

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority

# Optional: override DNS servers for MongoDB Atlas SRV lookups if your network blocks SRV/DNS.
# Example:
# DNS_SERVERS=8.8.8.8,1.1.1.1
DNS_SERVERS=

# Auth
JWT_SECRET=change_me

# Base URL used when building password reset links.
# If set, the reset link is built like: ${BACKEND_URL}/reset-password?token=<TOKEN>
# Examples:
# BACKEND_URL=http://localhost:5000
# BACKEND_URL=http://<YOUR_PC_LAN_IP>:5000
# BACKEND_URL=https://german-bharatham-backend.onrender.com
BACKEND_URL=

# Deprecated (older name). Not used by current code.
USER_RESET_PASSWORD_URL_BASE=

# SMTP (email sending)
# Example for Gmail SMTP (use an App Password, not your normal password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="German Bharatham <your-email@gmail.com>"
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional SMTP flags
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# Optional: ONLY for development debugging (returns resetLink in API response)
# DEV_RETURN_RESET_LINK=true
DEV_RETURN_RESET_LINK=false
