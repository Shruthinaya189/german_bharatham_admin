# Backend environment variables (copy to backend/.env)

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/german_bharatham

# Auth
JWT_SECRET=change_me

# Password reset link base (FULL URL of the reset screen/page)
# This value is used to build: <base>?token=<TOKEN>
# Examples:
# (Recommended for this project): point to the backend-hosted reset page:
# USER_RESET_PASSWORD_URL_BASE=http://localhost:5000/reset-password
# USER_RESET_PASSWORD_URL_BASE=http://<YOUR_PC_IPV4>:5000/reset-password
# Or point to a frontend reset page if you have one:
# USER_RESET_PASSWORD_URL_BASE=https://your-frontend-domain.com/reset-password
USER_RESET_PASSWORD_URL_BASE=

# SMTP (email sending)
# Example for Gmail SMTP (use an App Password, not your normal password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="German Bharatham <your-email@gmail.com>"
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional SMTP flags
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# Optional: ONLY for development debugging (returns resetLink in API response)
# DEV_RETURN_RESET_LINK=true
DEV_RETURN_RESET_LINK=false
